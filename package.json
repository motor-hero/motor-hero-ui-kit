{
  "name": "@motor-hero/ui-kit",
  "version": "0.5.1",
  "description": "Componentes React reutilizáveis para o ecossistema MotorHero — shadcn/ui + Tailwind CSS v4",
  "author": "MotorHero",
  "license": "UNLICENSED",
  "keywords": [
    "react",
    "ui-kit",
    "shadcn-ui",
    "tailwindcss",
    "components",
    "motorhero"
  ],
  "homepage": "https://ui.motorhero.com.br",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/motor-hero/motor-hero-ui-kit.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist -p tsconfig.build.json",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "docs:dev": "vite --config docs/vite.config.ts",
    "docs:build": "vite build --config docs/vite.config.ts",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "peerDependencies": {
    "clsx": "^2.0.0",
    "lucide-react": ">=0.400.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": ">=2.0.0"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "clsx": "^2.0.0",
    "highlight.js": "^11.11.1",
    "husky": "^9.1.7",
    "lucide-react": "^1.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^6.4.2"
  }
}
